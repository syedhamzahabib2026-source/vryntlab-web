# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# -----------------------------------------------------------------------------
# Contact form (`/api/contact`) — Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
# Optional: in development only, override CONTACT_FROM_EMAIL for the From header (see send-contact-email.ts).
# CONTACT_FROM_EMAIL_DEV=

# -----------------------------------------------------------------------------
# AI chat (`/api/chat`) — OpenRouter
# -----------------------------------------------------------------------------
# Required for chat replies. Without it, POST /api/chat returns 503.
OPENROUTER_API_KEY=

# Optional overrides (defaults are set in src/lib/ai/models.ts).
OPENROUTER_MODEL=
OPENROUTER_EXTRACT_MODEL=

# Optional HTTP headers for OpenRouter attribution.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=VryntLab

# -----------------------------------------------------------------------------
# Chat leads (Supabase) — optional; chat still works without persistence
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Production lead inserts: use service role (server-only; never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

LEAD_EMAIL_DEDUPE_HOURS=
# Stored on each row; default in code is vryntlab-site (see src/lib/config/brand.ts).
LEAD_SOURCE=

# -----------------------------------------------------------------------------
# Lead notifications (email + Slack) — after a successful insert only
# -----------------------------------------------------------------------------
# Optional: if unset, lead emails use CONTACT_TO_EMAIL / CONTACT_FROM_EMAIL (same as contact form).
LEAD_NOTIFY_EMAIL=
RESEND_FROM_EMAIL=

SLACK_LEAD_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_LEAD_CHANNEL=
SLACK_LEAD_DM_USER=

# -----------------------------------------------------------------------------
# Chat API tuning (optional)
# -----------------------------------------------------------------------------
# CHAT_VERBOSE_LOGS=1
# CHAT_RATE_LIMIT_MAX=45
# CHAT_RATE_LIMIT_WINDOW_MS=60000
